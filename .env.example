# ========================
# VPS Panel Configuration
# ========================

# Flask
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET_KEY=change-me-to-another-random-64-char-string

# Panel Database (Source of Truth)
PANEL_DB_HOST=localhost
PANEL_DB_PORT=3306
PANEL_DB_USER=pannel_user
PANEL_DB_PASSWORD=StrongPanelPass123!
PANEL_DB_NAME=pannel_db
PANEL_DB_SOCKET=/var/run/mysqld/mysqld.sock

# MySQL/MariaDB (Client Databases)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ADMIN_USER=pannel_admin
MYSQL_ADMIN_PASSWORD=StrongMySQLPass123!

# FTP Configuration
FTP_METHOD=vsftpd
FTP_USER_CONF_DIR=/etc/vsftpd_user_conf

# Apache Paths
APACHE_SITES_AVAILABLE=/etc/apache2/sites-available
APACHE_SITES_ENABLED=/etc/apache2/sites-enabled

# Web Root
WEB_ROOT=/var/www

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/pannel/panel.log

# Panel Info
PANEL_NAME=VPS Panel
PANEL_VERSION=2.0.0
