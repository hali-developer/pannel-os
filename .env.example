# ========================
# VPS Panel Configuration
# ========================

# Flask
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET_KEY=change-me-to-another-random-64-char-string

# PostgreSQL (Panel Metadata)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pannel_user
POSTGRES_PASSWORD=StrongPanelPass123!
POSTGRES_DB=pannel_db

# MySQL/MariaDB (Client Databases)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ADMIN_USER=pannel_admin
MYSQL_ADMIN_PASSWORD=StrongMySQLPass123!

# FTP Configuration
FTP_METHOD=vsftpd
FTP_USER_CONF_DIR=/etc/vsftpd_user_conf

# Nginx Paths
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled

# Web Root
WEB_ROOT=/var/www

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/pannel/panel.log

# Panel Info
PANEL_NAME=VPS Panel
PANEL_VERSION=2.0.0
