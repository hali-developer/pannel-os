# ========================
# VPS Panel v3.0 Configuration
# ========================

# Flask
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET_KEY=change-me-to-another-random-64-char-string

# Panel Database (Source of Truth)
PANEL_DB_HOST=localhost
PANEL_DB_PORT=5432
PANEL_DB_USER=pannel_user
PANEL_DB_PASSWORD=StrongPanelPass123!
PANEL_DB_NAME=pannel_db

# PostgreSQL (Client Databases)
POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5432
POSTGRESQL_ADMIN_USER=postgres
POSTGRESQL_ADMIN_PASSWORD=StrongPostgresPass123!

# DB Password Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
DB_PASSWORD_ENCRYPTION_KEY=change-me-generate-with-fernet

# Web Root
WEB_ROOT=/var/www

# SSL / Let's Encrypt (Certbot)
# Email used for certificate expiry notifications
SSL_ADMIN_EMAIL=admin@yourdomain.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/pannel/panel.log

# Panel Info
PANEL_NAME=VPS Panel
PANEL_VERSION=3.0.0
